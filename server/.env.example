PORT=3001
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173

# Local Postgres example:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/lofibooks
DATABASE_URL=postgresql://username:password@hostname:5432/lofibooks

# Use "require" for Azure/Postgres over TLS, "disable" for simple local dev only.
DATABASE_SSL_MODE=disable

# API secrets
OPENAI_API_KEY=
MSAL_CLIENT_ID=
